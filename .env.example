# =============================================================================
# Copy this file to .env, paste ONE free Groq key below, then: docker compose up
# =============================================================================
# DEFAULT = 100% FREE, NOTHING TO DOWNLOAD:
#   - LLM:        Groq free hosted API (just an API key)
#   - Embeddings: local fastembed (auto, no key, ~130MB cached on first run)
# No paid API keys are required.
# =============================================================================

# --- LLM provider -----------------------------------------------------------
# "groq" (free hosted, default) | "ollama" (free local) | "anthropic" | "openai"
LLM_PROVIDER=groq

# Groq — FREE. Create a key in 30s at: https://console.groq.com/keys
# This is the ONLY value you must fill in.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Free models: llama-3.3-70b-versatile (default), llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# --- Other LLM options (leave blank unless you switch LLM_PROVIDER) ----------
# Ollama (fully offline; downloads a model locally — only if you want that)
OLLAMA_MODEL=qwen2.5:3b
# Anthropic (paid)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# OpenAI (paid)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings -------------------------------------------------------------
# Local model via fastembed — no API key, downloaded automatically on first run.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Tracing (optional, free) -----------------------------------------------
# The app ALWAYS records a full trace per upload in MariaDB (viewable in the
# UI) — no key needed. Leave the Langfuse fields blank to keep it fully local.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Database (MariaDB) -----------------------------------------------------
DB_NAME=emissions
DB_USER=emissions
DB_PASSWORD=emissions
DB_ROOT_PASSWORD=rootpass
# Host port for MariaDB. 3307 avoids clashing with a locally-installed MySQL on
# 3306. The app talks to the DB internally, so this only affects host access.
DB_PORT=3307

# --- Vector DB (Qdrant) -----------------------------------------------------
QDRANT_PORT=6333

# --- Ports ------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=8501

# --- Pipeline defaults ------------------------------------------------------
# Prompt version used by the live UI upload flow: v1 | v2 | v3
DEFAULT_PROMPT_VERSION=v3
